# Copy this file to .env and fill in your keys.
# At least one LLM key is required.

# --- LLM (pick one) ---

# Option A: Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Option B: OpenAI or any compatible endpoint
OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=http://localhost:11434/v1  # Uncomment for Ollama

# Override the model (optional)
# AGENT_MODEL=claude-3-5-sonnet-20241022
# AGENT_MODEL=gpt-4o

# --- MCP server keys (add as needed) ---
# BRAVE_API_KEY=...   # for @modelcontextprotocol/server-brave-search
